{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "clan-logistics-vk-bot",
  "main": "src/main.js",
  "compatibility_date": "2024-12-30",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "clan-logistics-vk-bot-db",
      "database_id": "d9b7c3ee-bdd3-4ba8-a8d3-948055294559"
    }
  ],
  "vars": {
    "VK_API_VERSION": "5.199"
  },
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    }
  }
}
