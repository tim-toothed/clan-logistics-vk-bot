{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "clan-logistics-vk-bot",
  "main": "src/index.js",
  "compatibility_date": "2024-12-30",
  "vars": {
    "VK_API_VERSION": "5.199"
  },
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    }
  }
}
